# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Setup: message @BotFather → /newbot → copy token
#        then message your bot → visit https://api.telegram.org/bot<TOKEN>/getUpdates → copy id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── NAASA Credentials ─────────────────────────────────────────────────────────
NAASA_USERNAME=your_email@gmail.com
NAASA_PASSWORD=your_password

# Chukul Credentials (for authenticated broker endpoints)
CHUKUL_USERNAME=your_chukul_id
CHUKUL_PASSWORD=your_chukul_password

# Email Notification Settings
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
RECEIVER_EMAIL=your_email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Trading Bot Configuration
DRY_RUN=True
RUN_ONCE=False
POLL_INTERVAL=60
SLEEP_INTERVAL_CLOSED=60
MAX_DAILY_BUYS=2

# Signal Thresholds
BUY_THRESHOLD=3
SELL_THRESHOLD=-3
DEFAULT_BUY_QTY=10
BROKER_CONCENTRATION_THRESHOLD=0.40

# Concurrency
FETCH_MAX_WORKERS=8
